@using Tally.Web.Models

<div class="food-table-container">
    <div class="food-table-scroll">
        <table class="food-table">
            <tbody>
                @if (Items is not null)
                {
                    @foreach (var item in SortedItems)
                    {
                        <tr class="@GetRowClass(item)">
                            <td @onclick="@(() => OnRowClicked.InvokeAsync(item))" class="clickable-cell">@item.Name</td>
                            <td @onclick="@(() => OnRowClicked.InvokeAsync(item))" class="clickable-cell">@item.CreatedDate.ToShortDateString()</td>
                            <td @onclick="@(() => OnRowClicked.InvokeAsync(item))" class="clickable-cell">@GetAgeDays(item) days</td>
                            <td class="opened-cell" @onclick="@(() => MarkOpened(item))" @onclick:stopPropagation="true">
                                @if (item.OpenedDate.HasValue)
                                {
                                    <span>@item.OpenedDate.Value.ToShortDateString()</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" Style="color: white;" />
                                }
                            </td>
                            <td class="delete-cell" @onclick="@(() => OnDelete.InvokeAsync(item))" @onclick:stopPropagation="true">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Style="color: white;" />
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Items is null)
    {
        <MudProgressLinear Indeterminate="true" Class="mt-3" />
    }
    else if (!Items.Any())
    {
        <MudText Typo="Typo.body2" Class="mt-3" Align="Align.Center" Color="Color.Tertiary">No items to display.</MudText>
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<FoodItemDisplay>? Items { get; set; }

    [Parameter]
    public int DefaultShelfLifeDays { get; set; } = 7;

    [Parameter]
    public RenderFragment? HeaderContent { get; set; }

    [Parameter]
    public EventCallback<FoodItemDisplay> OnRowClicked { get; set; }

    [Parameter]
    public EventCallback<FoodItemDisplay> OnDelete { get; set; }

    [Parameter]
    public EventCallback<FoodItemDisplay> OnOpened { get; set; }

    private IEnumerable<FoodItemDisplay> SortedItems
        => Items!.OrderBy(i => i.CreatedDate);

    private int GetAgeDays(FoodItemDisplay item)
        => (int)(DateTime.UtcNow - item.CreatedDate).TotalDays;

    private async Task MarkOpened(FoodItemDisplay item)
    {
        if (!item.OpenedDate.HasValue)
        {
            item.OpenedDate = DateTime.UtcNow;
            await OnOpened.InvokeAsync(item);
        }
    }

    private string GetRowClass(FoodItemDisplay item)
    {
        var ageDays = GetAgeDays(item);
        var shelfLife = item.ShelfLifeDays > 0 ? item.ShelfLifeDays : DefaultShelfLifeDays;
        var ratio = (double)ageDays / shelfLife;

        return ratio switch
        {
            >= 1.0 => "row-expired",
            >= 0.75 => "row-danger",
            >= 0.5 => "row-warning",
            _ => "row-safe"
        };
    }
}}