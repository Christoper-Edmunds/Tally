@page "/"
@using Tally.Web.Models
@using Tally.Web.Components.Shared

<PageTitle>Dashboard</PageTitle>

<FoodExpiryTable Items="@_items"
                 DefaultShelfLifeDays="5"
                 OnRowClicked="HandleRowClicked"
                 OnDelete="HandleDelete" />

@code {
    private List<FoodItemDisplay>? _items;

    private static readonly string[] TestNames =
    {
        "Milk", "Bread", "Chicken", "Yoghurt", "Cheese", "Eggs", "Bacon",
        "Lettuce", "Tomatoes", "Butter", "Ham", "Salmon", "Cream", "Apples",
        "Carrots", "Mushrooms", "Spinach", "Prawns", "Sausages", "Beef Mince",
        "Orange Juice", "Hummus", "Pork Chops", "Grapes", "Cucumber",
        "Coleslaw", "Pasta Sauce", "Tofu", "Blueberries", "Soup", "Deli Turkey",
        "Cheddar", "Avocado"
    };

    private static readonly string[] TestCategories =
    {
        "Dairy", "Bakery", "Meat", "Dairy", "Dairy", "Eggs", "Meat",
        "Vegetables", "Vegetables", "Dairy", "Meat", "Seafood", "Dairy", "Fruit",
        "Vegetables", "Vegetables", "Vegetables", "Seafood", "Meat", "Meat",
        "Beverages", "Deli", "Meat", "Fruit", "Vegetables",
        "Deli", "Condiments", "Plant-Based", "Fruit", "Ready Meals", "Deli",
        "Dairy", "Fruit"
    };

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(300);

        _items = Enumerable.Range(0, 33).Select(i => new FoodItemDisplay
        {
            Id = i + 1,
            Name = TestNames[i],
            Category = TestCategories[i],
            CreatedDate = DateTime.UtcNow.AddDays(-Random.Shared.Next(1, 10)),
            ShelfLifeDays = Random.Shared.Next(3, 10)
        }).ToList();
    }

    private Task HandleRowClicked(FoodItemDisplay item)
    {
        // TODO: Open detail card
        return Task.CompletedTask;
    }

    private void HandleDelete(FoodItemDisplay item) => _items?.Remove(item);
}
